# Oddtasy server
# Copy to .env and fill in.

PORT=4100
# comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173

# TxLINE credentials — devnet host + token from the on-chain subscription flow.
# NEVER commit real values; keep them in .env only.
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_API_TOKEN=
TXLINE_GUEST_JWT=
FIXTURES_CACHE_MS=45000

# Social betting program / devnet defaults.
SOLANA_RPC=https://api.devnet.solana.com
ODDTASY_BETTING_PROGRAM_ID=cisSZzchpfV9kJTuqjSNeT7KZcv8dirUsb2kKcAAsyT
ODDTASY_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Resolver mode: the settlement worker signs lock/resolve/cancel.
# Build the IDL with `anchor build`, generate the keypair with
# `npx tsx scripts/init-config.ts` (kept out of git).
ODDTASY_PROGRAM_IDL=../betting-program/target/idl/club_pool.json
ODDTASY_RESOLVER_KEYPAIR=resolver-keypair.json

ODDTASY_DATA_FILE=data/oddtasy.json
ODDTASY_DEFAULT_STAKE_USDC=5
ODDTASY_DEFAULT_RAKE_BPS=500
ODDTASY_DEFAULT_MAX_ENTRIES=200

# Exact-score grid is 0,1,2,3,4+.
ODDTASY_CORRECT_SCORE_CAP=4

# Local testing only — unlocks POST /pools/:id/dev/resolve to settle a pool
# to a chosen outcome without waiting on a real match. Never set in prod.
ODDTASY_DEV_TOOLS=0
